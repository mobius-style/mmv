{
  "version": "2.0",
  "note": "Referential ambiguity + context-dependent patterns. Deictic expressions requiring prior context, bare verb commands, and continuation references.",
  "patterns": {
    "ja": [
      "あれ", "これ", "それ", "どれ",
      "あの(?:件|事|話|もの|やつ|人|子)",
      "この(?:件|事|話|もの|やつ|人|子)",
      "その(?:件|事|話|もの|やつ|人|子)",
      "例の", "さっきの", "先ほどの",
      "あいつ", "そいつ", "こいつ"
    ],
    "en": [
      "\\bthat thing\\b", "\\bthis thing\\b", "\\bthe thing\\b",
      "\\bthat one\\b", "\\bthis one\\b", "\\bthe other one\\b",
      "\\bthe stuff\\b", "\\bwhat we discussed\\b",
      "\\bwhat you mentioned\\b", "\\bthe one you said\\b",
      "\\b(?:do|try|use|fix|change|about|with)\\s+that\\b"
    ],
    "zh": [
      "那个(?:东西|事|事情|人|家伙|玩意)",
      "这个(?:东西|事|事情|人|家伙|玩意)",
      "(?:那|这)(?=(?:个|件)?(?:怎么样|怎样|如何|好不好|可以吗|对不对|是什么|行不行|呢|吗)|(?:个)?[，。？！\\s]|$)(?:个|件)",
      "(?:那|这)个(?=\\s*$)",
      "那件事", "这件事",
      "刚才(?:说|提|讲|问)的", "之前(?:说|提|讲|问)的",
      "(?:那|这|那个|这个)(?:玩意|玩意儿|家伙)"
    ],
    "ko": [
      "그것", "이것", "저것", "그거", "이거", "저거",
      "아까", "그때"
    ],
    "fr": [
      "\\bce truc\\b", "\\bcette chose\\b", "\\bça\\b", "\\bcela\\b",
      "\\ble truc\\b"
    ],
    "de": [
      "\\bdas ding\\b", "\\bdieses ding\\b", "\\bjenes\\b",
      "\\bdas da\\b"
    ],
    "es": [
      "\\beso\\b", "\\besto\\b", "\\baquello\\b",
      "\\besa cosa\\b", "\\blo de\\b"
    ],
    "pt": [
      "\\bisso\\b", "\\bisto\\b", "\\baquilo\\b",
      "\\baquela coisa\\b"
    ]
  },
  "context_dependent": {
    "ja_bare_verb_commands": [
      "^やって$", "^直して$", "^確認して$", "^送って$",
      "^消して$", "^変えて$", "^足して$", "^見せて$",
      "^貼って$", "^開けて$", "^閉じて$", "^戻して$", "^揃えて$"
    ],
    "ja_context_references": [
      "続き", "もっと(?:詳しく|教えて)?", "もう一回", "前の(?:やつ)?",
      "他には", "次は"
    ],
    "en_context_references": [
      "\\bmore\\b(?!\\s+(?:than|or|information about))",
      "\\bagain\\b", "\\bthe rest\\b",
      "\\bgo on\\b", "\\bcontinue\\b", "\\bas before\\b",
      "\\belaborate\\b", "\\bthe previous one\\b"
    ],
    "zh_context_references": [
      "继续", "再来", "接着",
      "接着说", "接着讲", "接着介绍",
      "继续说", "继续讲", "继续介绍",
      "後面", "后面的", "后面的(?:内容|部分|细节)",
      "下一个", "下一部分",
      "接下来", "接著", "接下來",
      "剩下(?:的|下来的|的内容)?",
      "更多(?:关于|內容|内容|细节|資料|资料|資訊|资讯|详情)?",
      "继续(?:学习|学|看|讨论|解释|说明|分析|介紹)",
      "繼續(?:說|講|學|看|討論|解釋|說明|分析|介紹)",
      "還有(?:嗎|呢)?", "还有(?:吗|呢)?",
      "下一步",
      "续(?:き|個|个)", "續(?:き|個|个)",
      "续个(?:故事|什么|什麼|东西|東西)",
      "續個(?:故事|什么|什麼|东西|東西)",
      "(?:帮|幫)(?:我|忙)?续(?:個|个|き)",
      "(?:帮|幫)(?:我|忙)?續(?:個|个|き)"
    ],
    "zh_bare_verb_commands": [
      "^解决(?:一下|下|吧|它|這個|这个|這段|这段)?(?:[，。？！]|$)",
      "^修复(?:一下|下|吧|它|這個|这个|這段|这段)?(?:[，。？！]|$)",
      "^修復(?:一下|下|吧|它|這個|这个|這段|这段)?(?:[，。？！]|$)",
      "^优化(?:一下|下|吧|它|這個|这个|這段|这段)?(?:[，。？！]|$)",
      "^處理(?:一下|下|吧|它|這個|这个|這段|这段)?(?:[，。？！]|$)",
      "^处理(?:一下|下|吧|它|這個|这个|這段|这段)?(?:[，。？！]|$)",
      "^改进(?:一下|下|吧|它|這個|这个)?(?:[，。？！]|$)",
      "^搞定(?:一下|吧|它|這個|这个|嗎|吗)?(?:[，。？！]|$)",
      "^继续(?:一下|吧|吧[，。])?$",
      "^繼續(?:一下|吧|吧[，。])?$",
      "^再来(?:一次|一下)?(?:[，。？！]|$)",
      "^接着(?:说|讲|下去)?(?:[，。？！]|$)",
      "^算了(?:吧)?(?:[，。？！]|$)",
      "^試試|^试试",
      "帮(?:我|忙)(?:解决|修复|优化|处理|改进|搞定|调|改|调整)一下(?:吧)?",
      "幫(?:我|忙)(?:解決|修復|優化|處理|改進|搞定|調|改|調整)一下(?:吧)?",
      "请帮(?:我|忙)(?:解决|修复|优化|处理|改进|搞定)(?:一下)?(?:吧)?",
      "請幫(?:我|忙)(?:解決|修復|優化|處理|改進|搞定)(?:一下)?(?:吧)?",
      "^(?:解决|修复|修復|优化|處理|处理|搞定)(?:这|這|那)[一-鿿]{1,12}(?:吧|啊|呢|[，。？！]|$)",
      "^(?:快|赶紧|趕緊)(?:修复|修復|解决|解決|优化|處理|处理)(?:一下)?"
    ],
    "ko_context_references": [
      "계속", "다시"
    ]
  }
}
