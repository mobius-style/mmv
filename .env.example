# MOBIUS MMV environment configuration template
#
# Copy this file to `.env` and fill in the values below. The `.env` file
# itself is gitignored (never commit it); only this `.env.example` is
# tracked in the repository.
#
# ─────────────────────────────────────────────────────────────────────────────
# External API keys
# ─────────────────────────────────────────────────────────────────────────────

# Brave Search API key — used by the web_search adapter for freshness-
# sensitive verify-route queries (Box C).
# Sign up and obtain a key at: https://brave.com/search/api/
BRAVE_API_KEY=

# Groq API key — used by the Self-Governance Protocol supervisor and by the
# RL evaluation harness's LLM judge (openai/gpt-oss-120b via Groq).
# Sign up and obtain a key at: https://console.groq.com/
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Local inference backend (Ollama)
# ─────────────────────────────────────────────────────────────────────────────

# Ollama HTTP endpoint (default is the local daemon).
OLLAMA_ENDPOINT=http://localhost:11434

# Primary Ollama model used by the answer/verify synthesis path.
# The reference model is `qwen3.5:9b`. See CLAUDE.md for the critical
# `think: false` requirement on `api/generate`.
OLLAMA_MODEL=qwen3.5:9b

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Vertex AI (stub; see src/adapters/web_search_adapter.py)
# ─────────────────────────────────────────────────────────────────────────────
#
# Leave blank unless you are wiring the Vertex AI fallback path.

# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=
# VERTEX_SEARCH_APP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: llama.cpp worker endpoints (used by some scripts)
# ─────────────────────────────────────────────────────────────────────────────

# LLAMA_WORKER_A=
# LLAMA_WORKER_B=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Hugging Face cache (avoids re-downloading sentence-transformers)
# ─────────────────────────────────────────────────────────────────────────────

# HF_HOME=~/.cache/huggingface
